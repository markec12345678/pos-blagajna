// Prisma schema za POS blagajno
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Kategorije izdelkov (npr. Pijače, Hrana, Sladice)
model Category {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#6B7280")
  position  Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Izdelki (artikli), ki se prodajajo
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  sku         String?  @unique
  stock       Int      @default(0)
  image       String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItems   SaleItem[]
}

// Posamezna prodaja (racun)
model Sale {
  id           String     @id @default(cuid())
  receiptNo    String     @unique
  subtotal     Float
  taxRate      Float      @default(0.22) // 22% DDV
  taxAmount    Float
  discount     Float      @default(0)
  total        Float
  paymentMethod String    @default("cash") // cash, card, mobile
  paidAmount   Float      @default(0)
  changeAmount Float      @default(0)
  status       String     @default("completed") // completed, refunded, voided
  customerId   String?
  customerName String?
  cashierId    String?
  cashierName  String?
  note         String?
  createdAt    DateTime   @default(now())
  items        SaleItem[]
}

// Posamezna postavka na racunu
model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String  // ime ob casu prodaje (za zgodovino)
  price     Float   // cena ob casu prodaje
  quantity  Float
  unit      String  @default("kos")
  total     Float
}

// Kupci (opcijsko)
model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
